# repoforge.yaml — per-repo configuration
# Rename to repoforge.yaml and place in your repo root

# Override project name (default: auto-detected from package.json / pyproject.toml)
# project_name: "My Awesome App"

# Force project type instead of auto-detecting.
# Options: web_service | frontend_app | cli_tool | library_sdk | data_science
#          mobile_app | desktop_app | infra_devops | monorepo | generic
# project_type: web_service

# Override layer detection (default: auto-detected from directory names)
# layers:
#   frontend: apps/web
#   backend: apps/api
#   shared: packages/shared
#   workers: apps/jobs

# Default documentation language (avoids passing --lang every time)
# language: Spanish

# Default LLM model (avoids passing --model every time)
# model: github/gpt-4o-mini

# Override auto-detected complexity (affects generation depth and verbosity).
# "auto" detects from file count + layer count.
# Options: auto | small | medium | large
#   small  → detailed skills, skip orchestrator/agents, fewer chapters
#   medium → standard depth (default behavior)
#   large  → concise skills, fewer per layer, more chapters
# complexity: auto

# Generate Claude Code hooks documentation (HOOKS.md) during skills generation.
# Hooks protect critical files, enforce linting, and suggest test runs.
# Can also be enabled with --with-hooks flag.
# generate_hooks: false

# Output targets for multi-tool support.
# Controls which AI coding tools receive generated output.
# Default: [claude, opencode]
# Valid: claude, opencode, cursor, codex, gemini, copilot
# Use "all" or list all to generate for every tool.
# Can also be set with --targets flag (CLI takes precedence).
# targets: [claude, opencode]
# targets: [claude, opencode, cursor, codex, gemini, copilot]  # all tools

# Generate plugin hierarchy (plugin.json + commands/ + PLUGIN.md) during skills generation.
# Organizes generated output into an installable, composable plugin format:
#   Skills   = Knowledge/patterns (SKILL.md files)
#   Commands = Executable workflows that chain multiple skills
#   Plugin   = Composable package with manifest, skills, commands, metadata
# Can also be enabled with --plugin flag.
# generate_plugin: false

# YAML-based chapter templates (replaces hardcoded ADAPTIVE_CHAPTERS).
# Templates live in repoforge/templates/ by default.
# You can override the template directory or force a specific project type template.
# templates:
#   path: ./my-templates/     # custom template directory (default: built-in templates)
#   override: web-service      # force a specific template regardless of auto-detection

# Page templates — control which SECTIONS appear within each generated page.
# Chapter templates define which files are generated; page templates define
# what content blocks appear inside each file.
#
# Section types: intro, outro, call_graph, entity_diff, diagram,
#                data_models, api_surface, custom
#
# pages:
#   - file: "03-architecture.md"
#     sections:
#       - type: intro
#         content: "This project follows a hexagonal architecture."
#       - type: call_graph
#         enabled: true
#       - type: entity_diff
#         enabled: false
#       - type: diagram
#         enabled: true
#       - type: custom
#         title: "Deployment Notes"
#         content: "We deploy via GitHub Actions to ECS."
#       - type: outro
#         content: "For questions, see the #architecture Slack channel."
#
# You can also use a standalone YAML file:
# pages:
#   path: ./page-templates.yaml
